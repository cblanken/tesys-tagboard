msgid "Details"
msgstr ""

msgid ""
"\n"
"        <p>Here are a few simple queries to get you started.</p>\n"
"        <p>This query will return all posts with the <em>blue</em> tag that "
"have more than 5 tags total and have been added to a collection.</p>\n"
"        <code class=\"p-3 px-4 bg-info text-info-content w-fit rounded-"
"field\">blue tag_count&lt;5 collection=yes</code>\n"
"        <p>This query will return all posts with a height of exactly 400 "
"pixels and more than 3 comments.</p>\n"
"        <code class=\"py-3 px-4 bg-info text-info-content w-fit rounded-"
"field\">height=400 comment_count>3</code>\n"
"        <p>This query will return all posts with a source URL on "
"<code>discord.com</code> that have not yet been rated. Note the wildcard at "
"the end of the source value that allows the source to match any URL "
"originating from Discord.</p>\n"
"        <code class=\"py-3 px-4 bg-info text-info-content w-fit rounded-"
"field\">source=https://discord.com* rating_label=unrated</code>\n"
"      "
msgstr ""

